PORT=10000
NODE_ENV=production
LOG_LEVEL=info

# Instagram OAuth
INSTAGRAM_APP_ID=your_instagram_app_id
INSTAGRAM_APP_SECRET=your_instagram_app_secret
INSTAGRAM_REDIRECT_URI=https://YOUR_RENDER_SERVICE.onrender.com/api/auth/instagram-callback
INSTAGRAM_API_VERSION=v21.0
INSTAGRAM_OAUTH_AUTHORIZE_URL=https://www.facebook.com/v21.0/dialog/oauth
INSTAGRAM_OAUTH_TOKEN_URL=https://graph.facebook.com/v21.0/oauth/access_token
INSTAGRAM_GRAPH_API_BASE_URL=https://graph.facebook.com/v21.0
INSTAGRAM_SCOPES=instagram_graph_api,instagram_manage_messages,instagram_basic,pages_manage_posts

# Persistence
# Use /var/data only when a persistent disk is attached in Render.
DB_PATH=/var/data/phone_studio.db

# API Security
APPROVAL_TOKEN=your_secure_random_token_here
JWT_SECRET=your_jwt_secret_here

# Frontend origin
PWA_ORIGIN=https://nothinginfinity.github.io/phone-studio

# Sync Settings
DM_SYNC_INTERVAL_MINUTES=5
POST_RETRY_MAX_ATTEMPTS=3
